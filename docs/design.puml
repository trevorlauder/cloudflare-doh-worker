@startuml Cloudflare-DoH-Worker

title Cloudflare DoH Worker Sequence Diagram

activate "DNS Client"

"DNS Client" -> "Cloudflare Worker": GET/POST https://cloudflare-worker-domain/endpoint/path

note over "Cloudflare Worker": Resolve {SECRET} placeholders\nParse DNS request\nTruncate ECS prefixes (if enabled)

alt Domain in ALLOWED_DOMAINS
group Single request (Bypass Provider only)
  "Cloudflare Worker" -> "Bypass Provider": GET/POST https://bypass-provider/dns-query
  "Cloudflare Worker" <- "Bypass Provider": Bypass Provider DNS Response
end

"Cloudflare Worker" -[#gray]-> "Grafana Loki": POST log entry (async, if configured)
"Cloudflare Worker" -> "DNS Client": Cloudflare Worker DNS Response
else Domain in BLOCKED_DOMAINS
  "Cloudflare Worker" -[#gray]-> "Grafana Loki": POST log entry (async, if configured)
  "Cloudflare Worker" -> "DNS Client": NXDOMAIN (synthetic)
else Domain not in ALLOWED_DOMAINS or BLOCKED_DOMAINS

opt Blocklist enabled (cold start)
  note over "Cloudflare Worker": Load shard metadata from\nbundled filter_meta module
end

note over "Cloudflare Worker": Hash domain to determine shard index
alt Shard in LRU cache (50 MB pool)
  note over "Cloudflare Worker": Check filter from cached shard
else Shard not cached
  "Cloudflare Worker" -> "Workers Assets": fetch shard_N.bin
  "Cloudflare Worker" <- "Workers Assets": Filter shard
  note over "Cloudflare Worker": Cache shard in LRU cache,\ncheck filter
end

alt Domain in blocklist
  "Cloudflare Worker" -[#gray]-> "Grafana Loki": POST log entry (async, if configured)
  "Cloudflare Worker" -> "DNS Client": NXDOMAIN (synthetic)
else Domain not blocked
group Parallel
  "Cloudflare Worker" -> "Main Provider": GET/POST https://main-provider/dns-query
  "Cloudflare Worker" <- "Main Provider": Main Provider DNS Response
  "Cloudflare Worker" -> "Additional Provider 1": GET/POST https://additional-provider-1/dns-query
  "Cloudflare Worker" <- "Additional Provider 1": Additional Provider 1 DNS Response
  "Cloudflare Worker" -> ...: GET/POST https://additional-provider-n/dns-query
  "Cloudflare Worker" <- ...: Additional Provider N DNS Response
end

note over "Cloudflare Worker": Select winner: blocked > possibly blocked\n> main provider > any provider\nApply rebind protection (if enabled)

"Cloudflare Worker" -[#gray]-> "Grafana Loki": POST log entry (async, if configured)
"Cloudflare Worker" -> "DNS Client": Cloudflare Worker DNS Response
end
end

@enduml
