{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "schedule": [
    "every weekend"
  ],
  "mise": {
    "managerFilePatterns": [
      "/(^|/)mise\\.toml$/",
      "/(^|/)mise\\.dev\\.toml$/"
    ]
  },
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^Dockerfile$/"
      ],
      "matchStrings": [
        "ARG MISE_VERSION=(?<currentValue>v[\\d.]+)\\n"
      ],
      "depNameTemplate": "jdx/mise",
      "datasourceTemplate": "github-releases"
    }
  ],
  "packageRules": [
    {
      "matchManagers": [
        "github-actions"
      ],
      "groupName": "github-actions"
    },
    {
      "matchManagers": [
        "mise"
      ],
      "groupName": "mise"
    },
    {
      "matchManagers": [
        "dprint"
      ],
      "groupName": "dprint"
    },
    {
      "matchManagers": [
        "pep621"
      ],
      "groupName": "python"
    },
    {
      "matchManagers": [
        "dockerfile"
      ],
      "groupName": "docker"
    }
  ]
}
